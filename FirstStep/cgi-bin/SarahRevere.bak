PROGRAM SarahRevere(INPUT, OUTPUT);
USES
  DOS; { Для функции GetEnv }
VAR
  QueryString: STRING;
BEGIN
  { Получаем строку запроса из переменной окружения }
  QueryString := GetEnv('QUERY_STRING');

  { Выводим HTTP-заголовки }
  WRITELN('Content-Type: text/plain');
  WRITELN; { Пустая строка, отделяющая заголовки от тела }

  { Анализируем значение параметра lanterns }
  IF QueryString = 'lanterns=1' THEN
    WRITELN('The British are coming by land.')
  ELSE IF QueryString = 'lanterns=2' THEN
    WRITELN('The British are coming by sea.')
  ELSE
    WRITELN('Sarah didn''t say');
END.
